BOOKSORT_SECRET_KEY=replace-with-a-long-random-secret
BOOKSORT_PASSWORD=replace-with-your-login-password

# Optional: only set this if you mount the Railway volume somewhere other than /app/instance.
# BOOKSORT_INSTANCE_PATH=/app/instance

# Optional: if you add Railway Postgres later, set DATABASE_URL instead of using SQLite.
# DATABASE_URL=postgresql://user:password@host:port/database
